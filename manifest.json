{
  "manifest_version": 3,
  "name": "Gemini Writer Assistant",
  "version": "1.0",
  "permissions": ["contextMenus", "activeTab", "scripting", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["toast.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
